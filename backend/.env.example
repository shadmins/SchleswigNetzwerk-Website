# ============================================================
# Schleswig-Netzwerk Backend – Environment Konfiguration
# Kopiere diese Datei zu .env und befülle die Werte
# ============================================================

# ----- Server -----
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
ACCOUNTS_URL=http://localhost

# ----- Datenbank (XAMPP MySQL) -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=schleswig_netzwerk

# ----- JWT -----
# Generiere mit: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=DEIN_GEHEIMER_JWT_SCHLUESSEL_HIER_AENDERN
JWT_EXPIRES_IN=7d

# ----- SMTP (Mailcow) -----
SMTP_HOST=mail.schleswignetzwerk.eu
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=system@schleswignetzwerk.eu
SMTP_PASS=DEIN_SMTP_PASSWORT
MAIL_FROM="Schleswig-Netzwerk <system@schleswignetzwerk.eu>"

# ----- Discord OAuth2 -----
DISCORD_CLIENT_ID=DEINE_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=DEIN_DISCORD_CLIENT_SECRET
DISCORD_REDIRECT_URI=http://localhost:3000/api/account/discord/callback

# ----- Discord Bot -----
DISCORD_BOT_TOKEN=DEIN_BOT_TOKEN
DISCORD_GUILD_ID=DEINE_SERVER_ID
DISCORD_VERIFIED_ROLE_ID=ROLLE_ID_FUER_VERIFIZIERTE_MEMBER

# ----- SSO (Authentic OIDC – für Edit-System) -----
SSO_ISSUER=https://auth.deinedomain.eu
SSO_CLIENT_ID=schleswig-netzwerk
SSO_CLIENT_SECRET=DEIN_SSO_SECRET
SSO_REDIRECT_URI=http://localhost:3000/api/sso/callback
SSO_ALLOWED_ROLES=admin,moderator,editor
